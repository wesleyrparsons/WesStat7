procedure minlbfgsoptimize(state: Tminlbfgsstate; func: Tndimensional_func; rep: Tndimensional_rep; obj: Pointer; _xparams: UInt64 = 0);overload;
var
    _s_error_msg: PAnsiChar;
    _error_code: Int32T;
    _b_result: Byte;
    _state: Pointer;
    buffers: _TRCommV2Buffers;
    request: _TRCommV2Request;
    job_idx: TALGLIBInteger;
    njobs: TALGLIBInteger;

begin
    _s_error_msg:=nil;
    _b_result:=0;
    _state:=state.ptr;

    //
    // Check correctness of function pointers
    //
    if not Assigned(func) then
        raise Exception.Create('ALGLIB: error in minlbfgsoptimize() (func is nil)');


    //
    // Create V2 protocol structures
    //
    buffers:=nil;
    request:=nil;
    try
        buffers:=_TRCommV2Buffers.Create;
        request:=_TRCommV2Request.Create(obj, 'minlbfgs');

        //
        // Main loop
        //
        _error_code := x_rcv2_minlbfgs_set_protocol_v2(@_s_error_msg, @_state, _xparams);
        if _error_code<>X_OK then
        begin
            if _error_code=X_ASSERTION_FAILED then
                raise Exception.Create(string(_s_error_msg))
            else
                raise Exception.Create('ALGLIB: unknown error during minlbfgs_set_protocol_v2() call');
        end;
        while True do
        begin
            //
            // Call iteration function.
            // Terminate iterations if it returned false.
            //
            _error_code := x_xv2_minlbfgsiteration(@_s_error_msg, @_b_result, @_state, _xparams);
            if _error_code<>X_OK then
            begin
                if _error_code=X_ASSERTION_FAILED then
                    raise Exception.Create(string(_s_error_msg))
                else
                    raise Exception.Create('ALGLIB: unknown error during minlbfgsiteration call');
            end;
            Assert(_state=state.ptr, 'ALGLIB: internal error (reference changed for non-out X-object)');
            if _b_result=0 then
                Break;
            
            //
            // Reverse communication interface V2
            //
            request.fetch(_state, x_rcv2_minlbfgs_offload_v2_request);
            buffers.resize(request);
            if request.request=3 then
            begin
                njobs := request.size*request.vars+request.size;
                for job_idx:=0 to njobs-1 do
                    _process_v2request_3phase0(request, job_idx, func, nil, nil, nil, buffers);
                _process_v2request_3phase1(request);
                request.send_reply();
                continue;
            end;
            if request.request=5 then
            begin
                njobs := request.size*request.vars+request.size;
                for job_idx:=0 to njobs-1 do
                    _process_v2request_5phase0(request, job_idx, func, nil, nil, nil, buffers);
                _process_v2request_5phase1(request);
                request.send_reply();
                continue;
            end;

            if request.request=-1 then
            begin
                if Assigned(rep) then
                    rep(request.reportx, request.reportf, obj);
                Continue;
            end;
            raise Exception.Create('ALGLIB: error in minlbfgsoptimize (some derivatives were not provided?)');
        end;
    finally
        request.Free;
        buffers.Free;
    end;
end;
