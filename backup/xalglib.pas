function Str2Vector(S: string):TVector;
var
    V:  TSVector;
    I:  TALGLIBInteger;
    tmpS: AnsiString;
    PP: PAnsiChar;
    R: Double;
begin
    V:=Str2SVector(S);
    SetLength(Result, Length(V));
    for I:=0 to Length(V)-1 do
    begin
        tmpS:=V[I]+'@';
        if not parse_real_delim(PAnsiChar(tmpS), '@', R, PP) then
            raise Exception.Create('ALGLIB: can not parse string');
        Result[I]:=R;
    end;
end;

