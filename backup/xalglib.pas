procedure copy_1d_to_x(const r: TVector; N: Integer; var x: x_vector);overload;
var
    I: NativeInt;
    Ptr: PDouble;
begin
    if x.cnt=0 then
        Exit;
    if Length(r)<N then
        raise Exception.Create('ALGLIB: copy_x_to_1d failed - sizes mismatch');
    if x.cnt<N then
        raise Exception.Create('ALGLIB: copy_x_to_1d failed - sizes mismatch');
    if x.Data.Valuetype<>DT_REAL then
