    Mask:=Format('%%.%d%s', [Abs(Dps), IfThen(Dps>0,'F','E')]);
    N:=Length(V);
    for i:=0 to N-1 do
    begin
        if I>0 then
            Result:=Result+',';
        if IsNan(V[I].X) or IsNan(V[I].Y) then
        begin
            Result:=Result+'NAN';
            Continue;
        end;
        if IsInfinite(V[I].X) or IsInfinite(V[I].Y) then
        begin
            Result:=Result+'INF';
            Continue;
        end;
        Result:=Result+CFmt(Mask,V[I]);
    end;
    Result:=Result+']';
end;

function FormatMatrix(const V: TBMatrix; Dps: Integer):string;overload;
var
    I, J, N, M: TALGLIBInteger;
    R: TBVector;
begin
    if (V=nil) or (Length(V)=0) then
        Exit('[]');
    Result:='[';
    N:=Length(V);
    SetLength(R, 1);
    for i:=0 to N-1 do
    begin
        if i<>0 then
            Result:=Result+',';
        M:=Length(V[I]);
        if Length(R)<M then
            SetLength(R, M);
        for J:=0 to M-1 do
            R[J]:=V[I,J];
        Result:=Result+FormatVector(R,Dps);
    end;
    Result:=Result+']';
end;

