        begin
            wait_for_value_at_origin:=False;
            xa:=request.queryData.Value[formula_Data.Value_offs+idx*3+0];
            xb:=request.queryData.Value[formula_Data.Value_offs+idx*3+1];
            w:=request.queryData.Value[formula_Data.Value_offs+idx*3+2];
            if w=0 then
                Continue;
            if xa<>request.queryData.Value[query_Data.Value_offs+var_idx] then
            begin
                buffers.tmpX[var_idx] := xa;
                if Assigned(func) then
                begin
                    f := 0;
                    //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    func(buffers.tmpX, f, request.obj);
                    buffers.tmpF[0] := f;
                end
                else if Assigned(pfunc) then
                begin
                    f := 0;
                    //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    pfunc(buffers.tmpX, buffers.tmpC, f, request.obj);
                    buffers.tmpF[0] := f;
                end
                else if Assigned(fvec) then
                begin
                    //!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    fvec(buffers.tmpX, buffers.tmpF, request.obj);
                end
                else if Assigned(pfvec) then
                begin
                    //!!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
                end
                else
                    raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
                buffers.tmpX[var_idx] := xprev;
                for t:=0 to m-1 do
                    request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]+buffers.tmpF[t];
            end
            else
            begin
                if idx<>fs-1 then
                    raise Exception.Create('ALGLIB: integrity check 9340 failed');
                wait_for_value_at_origin:=True;
            end;
            if xb<>request.queryData.Value[query_Data.Value_offs+var_idx] then
            begin
                buffers.tmpX[var_idx] := xb;
                if Assigned(func) then
                begin
                    f := 0;
                    //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    func(buffers.tmpX, f, request.obj);
                    buffers.tmpF[0] := f;
                end
                else if Assigned(pfunc) then
                begin
                    f := 0;
                    //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    pfunc(buffers.tmpX, buffers.tmpC, f, request.obj);
                    buffers.tmpF[0] := f;
                end
                else if Assigned(fvec) then
                begin
                    //!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    fvec(buffers.tmpX, buffers.tmpF, request.obj);
                end
                else if Assigned(pfvec) then
                begin
                    //!!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                    pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
                end
                else
                    raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
                buffers.tmpX[var_idx] := xprev;
                for t:=0 to m-1 do
                    request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]-buffers.tmpF[t];
            end
            else
            begin
                if idx<>fs-1 then
                    raise Exception.Create('ALGLIB: integrity check 9340 failed');
                wait_for_value_at_origin:=True;
            end;
            if wait_for_value_at_origin then
                Break;
            for t:=0 to m-1 do
                request.replydj[reply_dj_offs+t*n+var_idx] := w*request.replydj[reply_dj_offs+t*n+var_idx];
        end;
    end
    else
    begin
        //
        // Compute target value at the origin
        //
        query_idx := job_idx-request.size*request.vars;
        query_Data.Value_offs := query_idx*(request.vars+request.dim+request.vars*request.formulasize*3);
        reply_fi_offs   := query_idx*request.funcs;
        m := request.funcs;
        
        //
        // Copy inputs to buffers
        //
        for i:=0 to request.vars-1 do
            buffers.tmpX[i] := request.queryData.Value[query_Data.Value_offs+i];
        if request.dim>0 then
            for I:=0 to request.dim-1 do
                buffers.tmpC[i] := request.queryData.Value[query_Data.Value_offs+request.vars+i];
        
        //
        // Callback
        //
        if Assigned(func) then
        begin
            f := 0;
            //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            func(buffers.tmpX, f, request.obj);
            buffers.tmpF[0] := f;
        end
        else if Assigned(pfunc) then
        begin
            f := 0;
            //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            pfunc(buffers.tmpX, buffers.tmpC, f, request.obj);
            buffers.tmpF[0] := f;
        end
        else if Assigned(fvec) then
        begin
            //!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            fvec(buffers.tmpX, buffers.tmpF, request.obj);
        end
        else if Assigned(pfvec) then
        begin
            //!!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
        end
        else
            raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
        for t:=0 to m-1 do
            request.replyfi[reply_fi_offs+t] := buffers.tmpF[t];
    end;
end;

procedure _process_v2request_5phase1(request: _TRCommV2Request);
var
    query_idx, var_idx, n, m, fs, query_Data.Value_offs, formula_Data.Value_offs, reply_fi_offs, reply_dj_offs, idx, t: TALGLIBInteger;
    xa, xb, w: Double;
    refers_origin: Boolean;
begin
    //
    // Phase 1: compute parts of the numerical differentiation formula that DO depend on the value at origin.
    //
    // This phase does not need parallelism because all what we need is to add request.size*request.vars precomputed values.
    //
    for query_idx:=0 to request.size-1 do
        for var_idx:=0 to request.vars-1 do
        begin
            //
            // Compute parts of the numerical differentiation formula that do NOT depend
            // on the value at origin.
            //
            n := request.vars;
            m := request.funcs;
            fs := request.formulasize;
            query_Data.Value_offs   := query_idx*(n+request.dim+n*request.formulasize*3);
            formula_Data.Value_offs := query_Data.Value_offs+n+request.dim+var_idx*fs*3;
            reply_fi_offs     := query_idx*m;
            reply_dj_offs     := query_idx*n*m;
            for idx:=0 to fs-1 do
            begin
                refers_origin:=False;
                xa:=request.queryData.Value[formula_Data.Value_offs+idx*3+0];
                xb:=request.queryData.Value[formula_Data.Value_offs+idx*3+1];
                w:=request.queryData.Value[formula_Data.Value_offs+idx*3+2];
                if w=0 then
                    Continue;
                if xa=request.queryData.Value[query_Data.Value_offs+var_idx] then
                begin
                    if idx<>fs-1 then
                        raise Exception.Create('ALGLIB: integrity check 3545 failed');
                    refers_origin:=True;
                    for t:=0 to m-1 do
                        request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]+request.replyfi[reply_fi_offs+t];
                end;
                if xb=request.queryData.Value[query_Data.Value_offs+var_idx] then
                begin
                    if idx<>fs-1 then
                        raise Exception.Create('ALGLIB: integrity check 3545 failed');
                    refers_origin:=True;
                    for t:=0 to m-1 do
                        request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]-request.replyfi[reply_fi_offs+t];
                end;
                if not refers_origin then
                    Continue;
                for t:=0 to m-1 do
                    request.replydj[reply_dj_offs+t*n+var_idx] := w*request.replydj[reply_dj_offs+t*n+var_idx];
            end;
        end;
end;

