function Clone(const Src: Tmindfreport):Tmindfreport;overload;
begin
    Result.f := src.f;
    Result.iterationscount := src.iterationscount;
    Result.nfev := src.nfev;
    Result.bcerr := src.bcerr;
    Result.lcerr := src.lcerr;
    Result.nlcerr := src.nlcerr;
    Result.terminationtype := src.terminationtype;
    Result.timetotal := src.timetotal;
    Result.timesolver := src.timesolver;
    Result.timecallback := src.timecallback;
end;

procedure x_mindfreport_init(var x: x_mindfreport);
begin
    x.f := 0;
    x.iterationscount.longval := 0;
    x.nfev.longval := 0;
    x.bcerr := 0;
    x.lcerr := 0;
    x.nlcerr := 0;
    x.terminationtype.longval := 0;
    x.timetotal := 0;
    x.timesolver := 0;
    x.timecallback := 0;
end;

procedure x_mindfreport_clear(var x: x_mindfreport);
begin
end;

procedure x_mindfreport_init_from(var x: x_mindfreport; const v: Tmindfreport);
begin
    x.f := v.f;
    x.iterationscount.longval := v.iterationscount;
    x.nfev.longval := v.nfev;
    x.bcerr := v.bcerr;
    x.lcerr := v.lcerr;
    x.nlcerr := v.nlcerr;
    x.terminationtype.longval := v.terminationtype;
    x.timetotal := v.timetotal;
    x.timesolver := v.timesolver;
    x.timecallback := v.timecallback;
end;

procedure x_mindfreport_to_record(const x: x_mindfreport; var v: Tmindfreport);
begin
    v.f := x.f;
    v.iterationscount := x.iterationscount.val; // long is silently truncated to TALGLIBInteger
    v.nfev := x.nfev.val; // long is silently truncated to TALGLIBInteger
    v.bcerr := x.bcerr;
    v.lcerr := x.lcerr;
    v.nlcerr := x.nlcerr;
    v.terminationtype := x.terminationtype.val; // long is silently truncated to TALGLIBInteger
    v.timetotal := x.timetotal;
    v.timesolver := x.timesolver;
    v.timecallback := x.timecallback;
end;


procedure _core_mindfcreate(const  n: TALGLIBInteger; const  x: TVector; out  state: Tmindfstate; _xparams: UInt64);
var
    _s_error_msg:PAnsiChar;
    _error_code: Int32T;
    fpumask: XExceptionMask;
    _d_n: NativeInt;
    _d_x: x_vector;
    _d_state : Pointer;
begin
    _s_error_msg := nil;
    
    // Pack, call, unpack
    fpumask:=SetXExceptionMask(xMaskAllExceptions);
    try
        _d_n := n;
        x_from_array(_d_x, x, X_CREATE);
        _d_state := nil;
        state := nil;
        _error_code := x_xv2_mindfcreate(@_s_error_msg, @_d_n, @_d_x, @_d_state, _xparams);
        if _error_code<>X_OK then
        begin
            if _error_code=X_ASSERTION_FAILED then
                raise Exception.Create(string(_s_error_msg))
            else
                raise Exception.Create('ALGLIB: unknown error during mindfcreate call');
        end;
        state := Tmindfstate.Create(_d_state);
    finally
        SetXExceptionMask(fpumask);
        x_clear(_d_x);
        if (_d_state<>nil) and (state=nil) then
            x_obj_free_mindfstate(_d_state); // on exception clean up X objects which were not attached to Delphi objects
    end;
end;


