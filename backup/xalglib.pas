procedure _process_v2request_1(
                request:    _TRCommV2Request;
                query_idx:  TALGLIBInteger;
                sjac:       Tndimensional_sjac;
                psjac:      Tndimensional_psjac;
                buffers:    _TRCommV2Buffers);
var
    query_Data.Value_offs:TALGLIBInteger;
    reply_fi_offs: TALGLIBInteger;
    I, ridx: TALGLIBInteger;
begin
    //
    // Query and reply offsets
    //
    query_Data.Value_offs := query_idx*(request.vars+request.dim);
    reply_fi_offs   := query_idx*request.funcs;
            
    //
    // Copy inputs to buffers
    //
    for I:=0 to request.vars-1 do
        buffers.tmpX[i] := request.queryData.Value[query_Data.Value_offs+i];
    if request.dim>0 then
        for I:=0 to request.dim-1 do
            buffers.tmpC[i] := request.queryData.Value[query_Data.Value_offs+request.vars+i];
    sparsecreatecrsemptybuf(request.vars, buffers.tmpS);
            
    //
    // Callback
    //
    if Assigned(sjac) then
    begin
        sjac(buffers.tmpX, buffers.tmpF, buffers.tmpS, request.obj);
        for ridx:=0 to request.funcs-1 do
            request.replyfi[reply_fi_offs+ridx] := buffers.tmpF[ridx];
        sparseappendmatrix(request.replysj, buffers.tmpS);
        Exit;
    end;
    if Assigned(psjac) then
    begin
        psjac(buffers.tmpX, buffers.tmpC, buffers.tmpF, buffers.tmpS, request.obj);
        for ridx:=0 to request.funcs-1 do
            request.replyfi[reply_fi_offs+ridx] := buffers.tmpF[ridx];
        sparseappendmatrix(request.replysj, buffers.tmpS);
        Exit;
    end;
    raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
end;

procedure _process_v2request_2(
                request:    _TRCommV2Request;
                query_idx:  TALGLIBInteger;
                grad:       Tndimensional_grad;
                pgrad:      Tndimensional_pgrad;
                jac:        Tndimensional_jac;
                pjac:       Tndimensional_pjac;
                buffers:    _TRCommV2Buffers);
var
    query_Data.Value_offs:TALGLIBInteger;
    reply_fi_offs: TALGLIBInteger;
    reply_dj_offs: TALGLIBInteger;
    I, ridx, doffs: TALGLIBInteger;
    F0: Double;
begin
    //
    // Query and reply offsets
    //
    query_Data.Value_offs := query_idx*(request.vars+request.dim);
    reply_fi_offs   := query_idx*request.funcs;
    reply_dj_offs   := query_idx*request.funcs*request.vars;
            
    //
    // Copy inputs to buffers
    //
    for I:=0 to request.vars-1 do
        buffers.tmpX[i] := request.queryData.Value[query_Data.Value_offs+i];
    if request.dim>0 then
        for I:=0 to request.dim-1 do
            buffers.tmpC[i] := request.queryData.Value[query_Data.Value_offs+request.vars+i];
            
    //
    // Callback
    //
    if Assigned(grad) then
    begin
        f0 := 0;
        //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && request.funcs==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
        grad(buffers.tmpX, f0, buffers.tmpG, request.obj);
        request.replyfi[reply_fi_offs] := f0;
        for i:=0 to request.vars-1 do
            request.replydj[reply_dj_offs+i] := buffers.tmpG[i];
        Exit;
    end;
    if Assigned(pgrad) then
    begin
        f0 := 0;
        //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && request.funcs==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
        pgrad(buffers.tmpX, buffers.tmpC, f0, buffers.tmpG, request.obj);
        request.replyfi[reply_fi_offs] := f0;
        for I:=0 to request.vars-1 do
            request.replydj[reply_dj_offs+i] := buffers.tmpG[i];
        Exit;
    end;
    if Assigned(jac) then
    begin
        //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
        jac(buffers.tmpX, buffers.tmpF, buffers.tmpJ, request.obj);
        for ridx:=0 to request.funcs-1 do
        begin
            doffs := reply_dj_offs+ridx*request.vars;
            request.replyfi[reply_fi_offs+ridx] := buffers.tmpF[ridx];
            for I:=0 to request.vars-1 do
                request.replydj[doffs+i] := buffers.tmpJ[ridx,i];
        end;
        Exit;
    end;
    if Assigned(pjac) then
    begin
        //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
        pjac(buffers.tmpX, buffers.tmpC, buffers.tmpF, buffers.tmpJ, request.obj);
        for ridx:=0 to request.funcs-1 do
        begin
            doffs := reply_dj_offs+ridx*request.vars;
            request.replyfi[reply_fi_offs+ridx] := buffers.tmpF[ridx];
            for I:=0 to request.vars-1 do
                request.replydj[doffs+i] := buffers.tmpJ[ridx,i];
        end;
        Exit;
    end;
    raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
end;

procedure _process_v2request_3phase0(
            request:    _TRCommV2Request;
            job_idx:    TALGLIBInteger;
            func:       Tndimensional_func;
            pfunc:      Tndimensional_pfunc;
            fvec:       Tndimensional_fvec;
            pfvec:      Tndimensional_pfvec;
            buffers:    _TRCommV2Buffers);
var
    i, t, idx, query_idx, var_idx, n, m, fs, query_Data.Value_offs, formula_Data.Value_offs, reply_dj_offs, reply_fi_offs: TALGLIBInteger;
    xprev, xx, coeff, f: Double;
begin
    //
    // Phase 0: compute target at the origin and compute parts of the numerical differentiation formula that do NOT depend
    // on the value at origin.
    //
    // This job can be completely parallelized without synchronization.
    //
    if job_idx<request.size*request.vars then
    begin
        //
        // Compute parts of the numerical differentiation formula that do NOT depend
        // on the value at origin.
        //
        query_idx := job_idx div request.vars;
        var_idx   := job_idx mod request.vars;
        n := request.vars;
        m := request.funcs;
        fs :=request.formulasize;
        query_Data.Value_offs   := query_idx*(n+request.dim+n*request.formulasize*2);
        formula_Data.Value_offs := query_Data.Value_offs+n+request.dim+var_idx*fs*2;
        reply_dj_offs     := query_idx*n*m;
                
        //
        // Copy inputs to buffers
        //
        for i:=0 to request.vars-1 do
            buffers.tmpX[i] := request.queryData.Value[query_Data.Value_offs+i];
        if request.dim>0 then
            for I:=0 to request.dim-1 do
                buffers.tmpC[i] := request.queryData.Value[query_Data.Value_offs+request.vars+i];
                
        //
        // compute gradient using numerical differentiation formula provided by the optimizer
        //
        xprev := buffers.tmpX[var_idx];
        for t:=0 to m-1 do
            request.replydj[reply_dj_offs+t*n+var_idx] := 0;
        for idx:=0 to fs-1 do
        begin
            xx:=request.queryData.Value[formula_Data.Value_offs+idx*2+0];
            coeff:=request.queryData.Value[formula_Data.Value_offs+idx*2+1];
            if coeff=0 then
                Continue;
            if xx=request.queryData.Value[query_Data.Value_offs+var_idx] then // skip terms that depend on the target value at origin - it is still computed
                continue;
            buffers.tmpX[var_idx] := xx;
            if Assigned(func) then
            begin
                f := 0;
                //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                func(buffers.tmpX, f, request.obj);
                buffers.tmpF[0] := f;
            end
            else if Assigned(pfunc) then
            begin
                f := 0;
                //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                pfunc(buffers.tmpX, buffers.tmpC, f, request.obj);
                buffers.tmpF[0] := f;
            end
            else if Assigned(fvec) then
            begin
                //!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                fvec(buffers.tmpX, buffers.tmpF, request.obj);
            end
            else if Assigned(pfvec) then
            begin
                //!!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
                pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
            end
            else
                raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
            buffers.tmpX[var_idx] := xprev;
            for t:=0 to m-1 do
                request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]+coeff*buffers.tmpF[t];
        end;
    end
    else
    begin
        //
        // Compute target value at the origin
        //
        query_idx := job_idx-request.size*request.vars;
        query_Data.Value_offs := query_idx*(request.vars+request.dim+request.vars*request.formulasize*2);
        reply_fi_offs   := query_idx*request.funcs;
        m := request.funcs;
        
        //
        // Copy inputs to buffers
        //
        for i:=0 to request.vars-1 do
            buffers.tmpX[i] := request.queryData.Value[query_Data.Value_offs+i];
        if request.dim>0 then
            for I:=0 to request.dim-1 do
                buffers.tmpC[i] := request.queryData.Value[query_Data.Value_offs+request.vars+i];
        
        //
        // Callback
        //
        if Assigned(func) then
        begin
            f := 0;
            //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            func(buffers.tmpX, f, request.obj);
            buffers.tmpF[0] := f;
        end
        else if Assigned(pfunc) then
        begin
            f := 0;
            //!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0 && m==1, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            pfunc(buffers.tmpX, buffers.tmpC, f, request.obj);
            buffers.tmpF[0] := f;
        end
        else if Assigned(fvec) then
        begin
            //!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim==0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            fvec(buffers.tmpX, buffers.tmpF, request.obj);
        end
        else if Assigned(pfvec) then
        begin
            //!!!!!!!_ALGLIB_ASSERT_THROW_OR_BREAK(request.dim>0, std::string("ALGLIB: integrity check in '")+request.subpackage+"' subpackage failed; incompatible callback for optimizer request");
            pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
        end
        else
            raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
        for t:=0 to m-1 do
            request.replyfi[reply_fi_offs+t] := buffers.tmpF[t];
    end;
end;

procedure _process_v2request_3phase1(request: _TRCommV2Request);
var
    query_idx, var_idx, n, m, fs, query_Data.Value_offs, formula_Data.Value_offs, reply_fi_offs, reply_dj_offs, idx, t: TALGLIBInteger;
    xx, coeff: Double;
begin
    //
    // Phase 1: compute parts of the numerical differentiation formula that DO depend on the value at origin.
    //
    // This phase does not need parallelism because all what we need is to add request.size*request.vars precomputed values.
    //
    for query_idx:=0 to request.size-1 do
        for var_idx:=0 to request.vars-1 do
        begin
            //
            // Compute parts of the numerical differentiation formula that do NOT depend
            // on the value at origin.
            //
            n := request.vars;
            m := request.funcs;
            fs := request.formulasize;
            query_Data.Value_offs   := query_idx*(n+request.dim+n*request.formulasize*2);
            formula_Data.Value_offs := query_Data.Value_offs+n+request.dim+var_idx*fs*2;
            reply_fi_offs     := query_idx*m;
            reply_dj_offs     := query_idx*n*m;
            for idx:=0 to fs-1 do
            begin
                xx:=request.queryData.Value[formula_Data.Value_offs+idx*2+0];
                coeff:=request.queryData.Value[formula_Data.Value_offs+idx*2+1];
                if (coeff=0) or (xx<>request.queryData.Value[query_Data.Value_offs+var_idx]) then
                    continue;
                for t:=0 to m-1 do
                    request.replydj[reply_dj_offs+t*n+var_idx] := request.replydj[reply_dj_offs+t*n+var_idx]+coeff*request.replyfi[reply_fi_offs+t];
            end;
        end;
end;
        
