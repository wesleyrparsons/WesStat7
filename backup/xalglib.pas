procedure minmooptimize(state: Tminmostate; fvec: Tndimensional_fvec; rep: Tndimensional_rep; obj: Pointer; _xparams: UInt64 = 0);overload;
var
    _s_error_msg: PAnsiChar;
    _error_code: Int32T;
    _b_result: Byte;
    _xc_xupdated: Byte;
    _local_f: Double;
    _state: Pointer;
    _xc_arg: x_vector;
    _pas_arg: TVector;
    _xc_fi: x_vector;
    _pas_fi: TVector;
    _xc_needfi: Byte;
begin
    _s_error_msg:=nil;
    _b_result:=0;
    _xc_xupdated:=0;
    _state:=state.ptr;

    //
    // Check correctness of function pointers
    //
    if not Assigned(fvec) then
        raise Exception.Create('ALGLIB: error in minmooptimize() (fvec is nil)');

    //
    // Attach x-structures to internal arrays
    //
    x_create_empty(_xc_arg, DT_REAL);
    x_create_empty(_xc_fi, DT_REAL);
    x_minmostate_get_x(_state, @_xc_arg);
    x_minmostate_get_fi(_state, @_xc_fi);
    SetLength(_pas_arg, _xc_arg.cnt);
    SetLength(_pas_fi, _xc_fi.cnt);

    //
    // Main loop
    //
    _error_code := x_rcv2_minmo_set_protocol_v1(@_s_error_msg, @_state, _xparams);
    if _error_code<>X_OK then
    begin
        if _error_code=X_ASSERTION_FAILED then
            raise Exception.Create(string(_s_error_msg))
        else
            raise Exception.Create('ALGLIB: unknown error during minmo_set_protocol_v1() call');
    end;
    while True do
    begin
        //
        // Call iteration function.
        // Terminate iterations if it returned false.
        //
        _error_code := x_xv2_minmoiteration(@_s_error_msg, @_b_result, @_state, _xparams);
        if _error_code<>X_OK then
        begin
            if _error_code=X_ASSERTION_FAILED then
                raise Exception.Create(string(_s_error_msg))
            else
                raise Exception.Create('ALGLIB: unknown error during minmoiteration call');
        end;
        Assert(_state=state.ptr, 'ALGLIB: internal error (reference changed for non-out X-object)');
        if _b_result=0 then
            Break;
        
        //
        // Reverse communication interface:
        // * fetch flags
        // * call callbacks
        //
        x_minmostate_get_xupdated(_state, @_xc_xupdated);
        x_minmostate_get_needfi(_state, @_xc_needfi);
        x_to_array(_xc_arg, _pas_arg, True);
        if _xc_needfi<>0 then
        begin
            fvec(_pas_arg, _pas_fi, obj);
            x_from_array(_xc_fi, _pas_fi, X_REWRITE);
            Continue;
        end;
        if _xc_xupdated<>0 then
        begin
            if Assigned(rep) then
            begin
                x_minmostate_get_f(_state, @_local_f);
                rep(_pas_arg, _local_f, obj);
            end;
            Continue;
        end;
        raise Exception.Create('ALGLIB: error in minmooptimize (some derivatives were not provided?)');
    end;
end;
