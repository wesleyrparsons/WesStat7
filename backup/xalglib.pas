//
// this function creates array using x-vector as source.
// array is resized to fit exactly to source.
//
// exception is generated if types mismatch.
// x-vector is not freed after use.
//
procedure x_to_array(const x: x_vector; var r: TVector; NoRealloc: Boolean);overload;
var
    I, N: NativeInt;
    Ptr: PDouble;
begin
    if x.Data.Valuetype<>DT_REAL then
        raise Exception.Create('ALGLIB: x_to_array failed - types mismatch');
    if (not NoRealloc) and (Length(r)<>x.cnt) then
        SetLength(r, x.cnt);
    if Length(r)<>x.cnt then
        raise Exception.Create('ALGLIB: x_to_array failed - NoRealloc requested, sizes mismatch');
    N:=X.cnt;
    Ptr:=PDouble(x.xptr.ptr);
    for I:=0 to N-1 do  
    begin
        r[I]:=Ptr^;
        Inc(Ptr);
    end;
end;


