end;

destructor Tnlsstate.Destroy();
begin
    Deallocate();
end;

function Tnlsstate.Clone():Tnlsstate;
begin
    if ptr=nil then
        Result:=Tnlsstate.Create(nil)
    else
        Result:=Tnlsstate.Create(x_obj_copy_nlsstate(ptr));
end;

procedure Tnlsstate.Deallocate();
begin
    if ptr<>nil then
        x_obj_free_nlsstate(ptr);
    ptr:=nil;
end;

procedure Tnlsstate.DropReference();
begin
    ptr:=nil;
end;

function Tnlsstate.GetPtr():Pointer;
begin
    Result:=ptr;
end;

function Clone(const Src: Tnlsreport):Tnlsreport;overload;
begin
    Result.iterationscount := src.iterationscount;
    Result.terminationtype := src.terminationtype;
    Result.nfunc := src.nfunc;
end;

procedure x_nlsreport_init(var x: x_nlsreport);
begin
    x.iterationscount.longval := 0;
    x.terminationtype.longval := 0;
    x.nfunc.longval := 0;
end;

procedure x_nlsreport_clear(var x: x_nlsreport);
begin
end;

procedure x_nlsreport_init_from(var x: x_nlsreport; const v: Tnlsreport);
begin
    x.iterationscount.longval := v.iterationscount;
    x.terminationtype.longval := v.terminationtype;
    x.nfunc.longval := v.nfunc;
end;

procedure x_nlsreport_to_record(const x: x_nlsreport; var v: Tnlsreport);
begin
    v.iterationscount := x.iterationscount.val; // long is silently truncated to TALGLIBInteger
    v.terminationtype := x.terminationtype.val; // long is silently truncated to TALGLIBInteger
    v.nfunc := x.nfunc.val; // long is silently truncated to TALGLIBInteger
end;


