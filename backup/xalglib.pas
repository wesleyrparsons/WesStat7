destructor Tmindfstate.Destroy();
begin
    Deallocate();
end;

function Tmindfstate.Clone():Tmindfstate;
begin
    if ptr=nil then
        Result:=Tmindfstate.Create(nil)
    else
        Result:=Tmindfstate.Create(x_obj_copy_mindfstate(ptr));
end;

procedure Tmindfstate.Deallocate();
begin
    if ptr<>nil then
        x_obj_free_mindfstate(ptr);
    ptr:=nil;
end;

procedure Tmindfstate.DropReference();
begin
    ptr:=nil;
end;

function Tmindfstate.GetPtr():Pointer;
begin
    Result:=ptr;
