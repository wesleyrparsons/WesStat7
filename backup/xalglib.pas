function StreamReaderAdapter(StreamObj: NativeInt; Cnt: NativeInt; PDst: PAnsiChar):Byte;cdecl;
var
    Stream: TStream;
    C: AnsiChar;
    K: TALGLIBInteger;
begin
    try
        Stream:=TStream(Pointer(StreamObj));
        if Cnt<1 then
            Exit(1);
        while True do
        begin
            if Stream.Read(C,1)<1 then
                Exit(1);
            if (c<>' ') and (c<>Chr(9)) and (c<>Chr(10)) and (c<>Chr(13)) then
                Break;
        end;
        PDst[0]:=C;
        for k:=1 to cnt-1 do
        begin
            if Stream.Read(C,1)<1 then
                Exit(1);
            if (c=' ') or (c=Chr(9)) or (c=Chr(10)) or (c=Chr(13)) then
                Exit(1);
            PDst[k]:=C;
        end;
        PDst[Cnt]:=AnsiChar(0);
        Exit(0);
    except
        Exit(1);
    end;
end;

function StreamWriterAdapter(const PSrc: PAnsiChar; StreamObj: NativeInt):Byte;cdecl;
var
    Stream: TStream;
begin
    try
        Stream:=TStream(Pointer(StreamObj));
        Stream.Write(PSrc^, XStrLen(PSrc));
        Exit(0);
    except
        Exit(1);
    end;
end;


(****************************************************************
checks that matrix is symmetric.
max|A-A^T| is calculated; if it is within 1.0E-14 of max|A|,
matrix is considered symmetric
****************************************************************)
function xissymmetric(const a: TMatrix):Boolean;
var
    I, J, N: TALGLIBInteger;
    err, mx, v1, v2: Double;
begin
    if xrows(a)<>xcols(a) then
        Exit(False);
    n := xrows(a);
    if n=0 then
        Exit(true);
    mx := 0;
    err := 0;
    for i:=0 to N-1 do
    begin
        for j:=i+1 to N-1 do
        begin
            v1 := a[i,j];
            v2 := a[j,i];
            if isinfinite(v1) or  isnan(v1) then
                Exit(false);
            if isinfinite(v2) or  isnan(v2) then
                Exit(false);
            err := Max(err, Abs(v1-v2));
            mx  := Max(mx,  Abs(v1));
            mx  := Max(mx,  Abs(v2));
        end;
        v1 := a[i,i];
        if isinfinite(v1) or  isnan(v1) then
            Exit(false);
        mx := Max(mx, Abs(v1));
    end;
    if mx=0 then
        Exit(true);
    Exit(err/mx<=1.0E-14);
end;


(****************************************************************
checks that matrix is Hermitian.
max|A-A^H| is calculated; if it is within 1.0E-14 of max|A|,
matrix is considered Hermitian
****************************************************************)
function xishermitian(const a: TCMatrix):Boolean;
var
    i, j, n: TALGLIBInteger;
    err, mx: Double;
    v1, v2: Complex;
begin
    if xrows(a)<>xcols(a) then
        Exit(false);
    n := xrows(a);
    if n=0 then
        Exit(true);
    mx := 0;
    err := 0;
    for i:=0 to n-1 do
    begin
        for j:=i+1 to n-1 do
        begin
            v1 := a[i,j];
            v2 := a[j,i];
            if isinfinite(v1.x) or isnan(v1.x) then
                Exit(false);
            if isinfinite(v1.y) or isnan(v1.y) then
                Exit(false);
            if isinfinite(v2.x) or isnan(v2.x) then
                Exit(false);
            if isinfinite(v2.y) or isnan(v2.y) then
                Exit(false);
            err := Max(err, Abs(v1.x-v2.x));
            err := Max(err, Abs(v1.y+v2.y));
            mx  := Max(mx,  C_Abs(v1));
            mx  := Max(mx,  C_Abs(v2));
        end;
        v1 := a[i,i];
        if isinfinite(v1.x) or isnan(v1.x) then
            Exit(false);
        if isinfinite(v1.y) or isnan(v1.y) then
            Exit(false);
        err := Max(err, Abs(v1.y));
        mx  := Max(mx, C_Abs(v1));
    end;
    if mx=0 then
        Exit(true);
    Exit(err/mx<=1.0E-14);
end;


(****************************************************************
Enforces symmetricity by copying upper half of A to the lower one
****************************************************************)
function xforcesymmetric(a: TMatrix):Boolean;
var
    i, j, n: TALGLIBInteger;
begin
    if xrows(a)<>xcols(a) then
        Exit(false);
    n := xrows(a);
    if n=0 then
        Exit(true);
    for i:=0 to n-1 do
        for j:=i+1 to n-1 do
            a[i,j] := a[j,i];
    Exit(true);
end;

(****************************************************************
Forces Hermiticity by copying upper half of A to the lower one
****************************************************************)
function xforcehermitian(a: TCMatrix):Boolean;
var
    i, j, n: TALGLIBInteger;
    v: complex;
begin
    if xrows(a)<>xcols(a) then
        Exit(false);
    n := xrows(a);
    if n=0 then
        Exit(true);
    for i:=0 to n-1 do
        for j:=i+1 to n-1 do
        begin
            v := a[j,i];
            a[i,j].x := v.x;
            a[i,j].y := -v.y;
        end;
    Exit(true);
end;

constructor _TRCommV2Request.Create(param: Pointer; SName: AnsiString);
begin
    obj:=param;
    subpackage:=SName;
    ptr_reportx:=nil;
    reportf:=0;
    ptr_queryData.Value:=nil;
    ptr_replyfi:=nil;
    ptr_replydj:=nil;
    request:=0;
    size:=0;
    funcs:=0;
    vars:=0;
    dim:=0;
    formulasize:=0;
    tmp_xv.cnt:=0;
    tmp_xv.Data.Valuetype:=DT_REAL;
    tmp_xv.owner:=OWN_CALLER;
    tmp_xv.last_action:=0;
    tmp_xv.xptr.ptr:=nil;
    reportx:=nil;
    queryData.Value:=nil;
    replyfi:=nil;
    replydj:=nil;
    replysj:=nil;
end;

destructor _TRCommV2Request.Destroy();
begin
    if Assigned(replysj) then
    begin
        replysj.DropReference();
        replysj.Destroy();
    end;
end;

procedure _TRCommV2Request.fetch(inner_ptr: Pointer; fetch_func: TRCommV2OffloadFunc);
var
    need_len, qd_len, rf_len, rd_len: TALGLIBInteger;
begin
    fetch_func(inner_ptr, request, size, funcs, vars, dim, formulasize, ptr_reportx, reportf, ptr_queryData.Value, ptr_replyfi, ptr_replydj, ptr_replysj);
    if request=-1 then
    begin
        need_len := vars;
        tmp_xv.cnt := need_len;
        tmp_xv.xptr.ptr := ptr_reportx;
        if XLen(reportx)<need_len then
            SetLength(reportx,need_len);
        copy_x_to_1d(tmp_xv, reportx);
    end
    else if request=1 then
    begin
        qd_len := size*(vars+dim);
        rf_len := size*funcs;
        //
        tmp_xv.cnt := qd_len;
        tmp_xv.xptr.ptr := ptr_queryData.Value;
        if xlen(queryData.Value)<qd_len then
            SetLength(queryData.Value, qd_len);
        copy_x_to_1d(tmp_xv, queryData.Value);
        //
        if xlen(replyfi)<rf_len then
            SetLength(replyfi, rf_len);
        //
        if not Assigned(replysj) then
        begin
            replysj:=Tsparsematrix.Create(ptr_replysj);
        end
        else if ptr_replysj<>replysj.GetPtr() then
        begin
            replysj.Free;
            replysj:=Tsparsematrix.Create(ptr_replysj);
        end;
    end
    else if (request=2) or (request=3) or (request=4) or (request=5) then
    begin
        qd_len := size*(vars+dim);
        if request=3 then
            qd_len := size*(vars+dim+vars*2*formulasize);
        if request=5 then
            qd_len := size*(vars+dim+vars*3*formulasize);
        rf_len := size*funcs;
        if (request=2) or (request=3) or (request=5) then
            rd_len := size*funcs*vars
        else
            rd_len := 0;
        //
        tmp_xv.cnt := qd_len;
        tmp_xv.xptr.ptr := ptr_queryData.Value;
        if xlen(queryData.Value)<qd_len then
            SetLength(queryData.Value, qd_len);
        copy_x_to_1d(tmp_xv, queryData.Value);
        //
        if xlen(replyfi)<rf_len then
            SetLength(replyfi, rf_len);
        //
        if xlen(replydj)<rd_len then
            SetLength(replydj, rd_len);
    end
    else
        raise Exception.Create('ALGLIB: unexpected request type for RCOMM-V2 protocol');
end;

procedure _TRCommV2Request.send_reply();
var
    rf_len, rd_len: TALGLIBInteger;
begin
    rf_len := size*funcs;
    if (request=2) or (request=3) or (request=5) then
        rd_len := size*funcs*vars
    else
        rd_len := 0;
    //
    if rf_len>0 then
    begin
        tmp_xv.cnt := rf_len;
        tmp_xv.xptr.ptr := ptr_replyfi;
        copy_1d_to_x(replyfi, rf_len, tmp_xv);
    end;
    //
    if rd_len>0 then
    begin
        tmp_xv.cnt := rd_len;
        tmp_xv.xptr.ptr := ptr_replydj;
        copy_1d_to_x(replydj, rd_len, tmp_xv);
    end;
    // no need to send replysj because it is already attached to the destination matrix
end;

constructor _TRCommV2Buffers.Create();
begin
    tmpX:=nil;
    tmpC:=nil;
    tmpF:=nil;
    tmpG:=nil;
    tmpJ:=nil;
    tmpS:=nil;
end;

destructor _TRCommV2Buffers.Destroy();
begin
    tmpS.Free();
end;

procedure _TRCommV2Buffers.resize(request: _TRCommv2Request);
begin
    if XLen(tmpX)<request.vars then
        SetLength(tmpX, request.vars);
    if (request.dim>0) and (XLen(tmpC)<request.dim) then
        SetLength(tmpC, request.dim);
    if XLen(tmpF)<request.funcs then
        SetLength(tmpF, request.funcs);
    if XLen(tmpG)<request.vars then
        SetLength(tmpG, request.vars);
    if (request.request=1) and not Assigned(tmpS) then
        sparsecreatecrsempty(request.vars, tmpS);
    if (request.request=2) and ((XRows(tmpJ)<request.funcs) or (XCols(tmpJ)<request.vars)) then
        SetLength(tmpJ, request.funcs, request.vars);
end;


