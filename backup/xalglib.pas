constructor Tmcmcstate.Create(x_obj: Pointer);
begin
    ptr:=x_obj;
end;

destructor Tmcmcstate.Destroy();
begin
    Deallocate();
end;

function Tmcmcstate.Clone():Tmcmcstate;
begin
    if ptr=nil then
        Result:=Tmcmcstate.Create(nil)
    else
        Result:=Tmcmcstate.Create(x_obj_copy_mcmcstate(ptr));
end;

procedure Tmcmcstate.Deallocate();
begin
    if ptr<>nil then
        x_obj_free_mcmcstate(ptr);
    ptr:=nil;
end;

procedure Tmcmcstate.DropReference();
begin
    ptr:=nil;
end;

function Tmcmcstate.GetPtr():Pointer;
begin
    Result:=ptr;
end;

function Clone(const Src: Tmcmcreport):Tmcmcreport;overload;
begin
    Result.nfev := src.nfev;
    Result.acceptrate := src.acceptrate;
    Result.autocorrtimes := Clone(src.autocorrtimes);
end;

procedure x_mcmcreport_init(var x: x_mcmcreport);
begin
    x.nfev.longval := 0;
    x.acceptrate := 0;
    x_create_empty(x.autocorrtimes, DT_REAL);
end;

procedure x_mcmcreport_clear(var x: x_mcmcreport);
begin
    x_clear(x.autocorrtimes);
end;

procedure x_mcmcreport_init_from(var x: x_mcmcreport; const v: Tmcmcreport);
begin
    x.nfev.longval := v.nfev;
    x.acceptrate := v.acceptrate;
    x_from_array(x.autocorrtimes, v.autocorrtimes, X_CREATE);
end;

procedure x_mcmcreport_to_record(const x: x_mcmcreport; var v: Tmcmcreport);
begin
    v.nfev := x.nfev.val; // long is silently truncated to TALGLIBInteger
    v.acceptrate := x.acceptrate;
    x_to_array(x.autocorrtimes, v.autocorrtimes, False);
end;


