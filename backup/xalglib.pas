        pfvec(buffers.tmpX, buffers.tmpC, buffers.tmpF, request.obj);
        for ridx:=0 to request.funcs-1 do
            request.replyfi[reply_fi_offs+ridx] := buffers.tmpF[ridx];
        Exit;
    end;
    raise Exception.Create('ALGLIB: integrity check in "'+request.subpackage+'" subpackage failed; no callback for optimizer request');
